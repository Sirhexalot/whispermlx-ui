#!/bin/zsh
set -euo pipefail

root="${0:A:h}"
if [[ -n "${WHISPERMLX_CLI:-}" ]]; then
  cli="$WHISPERMLX_CLI"
elif [[ -x "$root/whispermlx" ]]; then
  cli="$root/whispermlx"
else
  cli="${root:h}/Resources/bin/whispermlx"
fi

system_language=$(plutil -extract AppleLanguages.0 raw -o - "$HOME/Library/Preferences/.GlobalPreferences.plist" 2>/dev/null || print en)

if [[ "${system_language:l}" == de* ]]; then
  file_prompt="Audio- oder Videodatei auswählen"
  model_prompt="Transkriptionsmodell auswählen"
  speaker_prompt="Sprechertrennung mit pyannote verwenden?"
  done_message="Fertig. Die Dateien liegen neben dem Original im Ordner .transkript."
  error_message="Die Transkription wurde mit Fehler beendet."
else
  file_prompt="Select an audio or video file"
  model_prompt="Select transcription model"
  speaker_prompt="Use speaker diarization with pyannote?"
  done_message="Done. Files are in the .transkript folder next to the original."
  error_message="The transcription ended with an error."
fi

input=$(osascript - "$file_prompt" <<'APPLESCRIPT'
on run argv
  set selectedFile to choose file with prompt (item 1 of argv) of type {"public.audio", "public.movie"}
  return POSIX path of selectedFile
end run
APPLESCRIPT
) || exit 0

selection=$(osascript - "$model_prompt" <<'APPLESCRIPT'
on run argv
  choose from list {"Schnell / Fast – large-v3-turbo", "Genau / Accurate – large-v3", "Kompakt / Compact – small"} with prompt (item 1 of argv) default items {"Genau / Accurate – large-v3"}
end run
APPLESCRIPT
) || exit 0
case "$selection" in
  "Genau / Accurate – large-v3") model="large-v3" ;;
  *"small"*) model="small" ;;
  *) model="large-v3-turbo" ;;
esac

speaker_choice=$(osascript - "$speaker_prompt" <<'APPLESCRIPT'
on run argv
  choose from list {"Nein / No", "Automatisch / Automatic", "2 Personen / 2 speakers", "3 Personen / 3 speakers", "4 Personen / 4 speakers", "5 Personen / 5 speakers", "6 Personen / 6 speakers"} with prompt (item 1 of argv) default items {"Automatisch / Automatic"}
end run
APPLESCRIPT
) || exit 0
case "$speaker_choice" in
  "Automatisch / Automatic") diarize=" --diarize" ;;
  "2 Personen / 2 speakers") diarize=" --diarize --min_speakers 2 --max_speakers 2" ;;
  "3 Personen / 3 speakers") diarize=" --diarize --min_speakers 3 --max_speakers 3" ;;
  "4 Personen / 4 speakers") diarize=" --diarize --min_speakers 4 --max_speakers 4" ;;
  "5 Personen / 5 speakers") diarize=" --diarize --min_speakers 5 --max_speakers 5" ;;
  "6 Personen / 6 speakers") diarize=" --diarize --min_speakers 6 --max_speakers 6" ;;
  *) diarize="" ;;
esac

output_dir="${input:r}.transkript"
log_file="$output_dir/transkription.log"

command=$(cat <<EOF
clear
printf '\\033]0;WhisperMLX UI – Transkription\\007'
print -P '%F{cyan}WhisperMLX UI%f'
print '────────────────────────────────────────'
print 'Transkription läuft …'
print "Datei: ${(q)input}"
print "Modell: ${(q)model}"
print "Ausgabe: ${(q)output_dir}"
print ''
mkdir -p ${(q)output_dir}
${(q)cli} ${(q)input} --model ${(q)model}${diarize} > ${(q)log_file} 2>&1 &
process_id=\$!
seconds=0
while kill -0 "\$process_id" 2>/dev/null; do
  printf '\\rVerarbeite die Aufnahme … %s Sekunden' "\$seconds"
  sleep 1
  (( seconds += 1 ))
done
wait "\$process_id"
exit_status=\$?
print ''
print ''
if (( exit_status == 0 )); then
  print -P '%F{green}${(q)done_message}%f'
else
  print -P '%F{red}${(q)error_message}%f'
  print "Details: ${(q)log_file}"
fi
print ''
print 'Dieses Fenster kann jetzt geschlossen werden.'
EOF
)
run_script=$(mktemp "${TMPDIR:-/tmp}/whispermlx-ui.XXXXXX")
print -r -- "$command"$'\nrm -f -- "$0"\n' > "$run_script"
chmod 700 "$run_script"
terminal_command="/bin/zsh ${(q)run_script}"
osascript - "$terminal_command" <<'APPLESCRIPT'
on run argv
  tell application "Terminal"
    activate
    do script (item 1 of argv)
  end tell
end run
APPLESCRIPT
