#!/bin/zsh
set -euo pipefail

if (( $# == 0 )) || [[ "$1" == "-h" || "$1" == "--help" ]]; then
  print 'Usage: whispermlx <audio-or-video-file> [whispermlx options]'
  exit 0
fi

input="$1"
shift
[[ -f "$input" ]] || { print -u2 "File not found: $input"; exit 2; }
input="${input:A}"
base="${input:t:r}"
output_dir="${input:h}/${base}.transkript"
typeset -a extra
extra=("$@")

if [[ " ${extra[*]} " == *" --diarize "* ]]; then
  [[ -n "${HF_TOKEN:-}" ]] || { print -u2 "Missing Hugging Face token. Save it in the app settings before enabling speaker diarization."; exit 3; }
  [[ " ${extra[*]} " == *" --hf_token "* ]] || extra=(--hf_token "$HF_TOKEN" "${extra[@]}")
fi

[[ " ${extra[*]} " == *" --model "* ]] || extra=(--model large-v3-turbo "${extra[@]}")
[[ " ${extra[*]} " == *" --output_format "* || " ${extra[*]} " == *" -f "* ]] || extra=(--output_format all "${extra[@]}")
[[ " ${extra[*]} " == *" --output_dir "* || " ${extra[*]} " == *" -o "* ]] || extra=(--output_dir "$output_dir" "${extra[@]}")

mkdir -p "$output_dir"
print "Transcribing: $input"
print "Output: $output_dir"
export PYTHONWARNINGS="${PYTHONWARNINGS:+${PYTHONWARNINGS},}ignore::UserWarning:pyannote.audio.core.io"
if [[ -n "${WHISPERMLX_PYTHON:-}" ]]; then
  python="$WHISPERMLX_PYTHON"
elif [[ -x "${0:A:h:h}/python/bin/python" ]]; then
  # Future self-contained app runtime, located at Contents/Resources/python.
  python="${0:A:h:h}/python/bin/python"
elif [[ -x "$HOME/.local/share/whispermlx-ui/venv/bin/python" ]]; then
  # Managed application runtime. The bare Homebrew interpreter does not carry
  # WhisperMLX and must not be selected before this environment.
  python="$HOME/.local/share/whispermlx-ui/venv/bin/python"
elif [[ -x "/opt/homebrew/opt/python@3.13/bin/python3.13" ]]; then
  python="/opt/homebrew/opt/python@3.13/bin/python3.13"
elif (( $+commands[python3.13] )); then
  python="${commands[python3.13]}"
elif (( $+commands[python3] )); then
  python="${commands[python3]}"
else
  python=""
fi
[[ -x "$python" ]] || {
  print -u2 "Python with WhisperMLX is not available. Install it with: brew install python@3.13 && /opt/homebrew/opt/python@3.13/bin/python3.13 -m pip install --upgrade whispermlx"
  exit 4
}
exec "$python" -m whispermlx "$input" "${extra[@]}"
