      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "FFmpeg fehlt. Es wird benötigt, um Mikrofon und Systemaudio zusammenzuführen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "FFmpeg is missing. It is required to mix microphone and system audio."
          }
        }
