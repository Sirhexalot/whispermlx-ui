    "error.audioMixingFailed": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofon und Systemaudio konnten nicht zusammengeführt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone and system audio could not be mixed."
          }
        }
